generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role     @default(VIEWER)
  department    String?
  avatarUrl     String?
  createdAt     DateTime @default(now())

  assignedIncidents   Incident[]       @relation("AssignedTo")
  reportedIncidents   Incident[]       @relation("ReportedBy")
  assignedRisks       Risk[]           @relation("RiskOwner")
  assignedActions     CorrectiveAction[] @relation("ActionOwner")
  assignedChanges     ChangeRequest[]  @relation("ChangeOwner")
  comments            Comment[]
  notifications       Notification[]
  auditLogs           AuditLog[]
}

enum Role {
  ADMIN
  MANAGER
  ANALYST
  VIEWER
}

model Incident {
  id            String          @id @default(cuid())
  ticketNumber  String          @unique
  title         String
  description   String
  category      IncidentCategory
  severity      Severity
  status        IncidentStatus  @default(OPEN)
  priority      Priority        @default(MEDIUM)
  assignedToId  String?
  assignedTo    User?           @relation("AssignedTo", fields: [assignedToId], references: [id])
  reportedById  String
  reportedBy    User            @relation("ReportedBy", fields: [reportedById], references: [id])
  isoClause     String?
  dueDate       DateTime?
  resolvedAt    DateTime?
  attachments   Attachment[]
  comments      Comment[]
  auditLogs     AuditLog[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum IncidentCategory {
  SECURITY
  OPERATIONS
  COMPLIANCE
  IT
  HR
  FINANCIAL
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  PENDING_REVIEW
  RESOLVED
  CLOSED
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

model Risk {
  id              String      @id @default(cuid())
  riskNumber      String      @unique
  category        RiskCategory
  statement       String
  description     String?
  inherentRating  RiskLevel
  residualRating  RiskLevel
  acceptableLevel RiskLevel
  ownerId         String?
  owner           User?       @relation("RiskOwner", fields: [ownerId], references: [id])
  status          RiskStatus  @default(OPEN)
  isoClause       String?
  identifiedDate  DateTime
  reviewDate      DateTime?
  dueDate         DateTime?
  mitigationPlan  String?
  comments        Comment[]
  auditLogs       AuditLog[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum RiskCategory {
  OPERATIONS_SECURITY
  ASSET_MANAGEMENT
  ACCESS_CONTROL
  SUPPLIER_RELATIONS
  BUSINESS_CONTINUITY
  PHYSICAL_SECURITY
  HUMAN_RESOURCES
  COMPLIANCE
}

enum RiskLevel {
  HIGH
  MEDIUM
  LOW
}

enum RiskStatus {
  OPEN
  MITIGATING
  ACCEPTED
  CLOSED
}

model CorrectiveAction {
  id            String       @id @default(cuid())
  caNumber      String       @unique
  title         String
  description   String
  rootCause     String?
  sourceType    String
  sourceId      String?
  assignedToId  String?
  assignedTo    User?        @relation("ActionOwner", fields: [assignedToId], references: [id])
  status        ActionStatus @default(OPEN)
  priority      Priority     @default(MEDIUM)
  dueDate       DateTime?
  completedAt   DateTime?
  verifiedAt    DateTime?
  effectiveness String?
  comments      Comment[]
  auditLogs     AuditLog[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  VERIFIED
  CLOSED
}

model ChangeRequest {
  id              String        @id @default(cuid())
  changeNumber    String        @unique
  title           String
  description     String
  changeType      ChangeType
  impactLevel     Severity
  status          ChangeStatus  @default(DRAFT)
  requestedById   String?
  assignedToId    String?
  assignedTo      User?         @relation("ChangeOwner", fields: [assignedToId], references: [id])
  approvedById    String?
  scheduledDate   DateTime?
  implementedAt   DateTime?
  rollbackPlan    String?
  testingPlan     String?
  comments        Comment[]
  auditLogs       AuditLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum ChangeType {
  STANDARD
  NORMAL
  EMERGENCY
}

enum ChangeStatus {
  DRAFT
  SUBMITTED
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
  ROLLED_BACK
}

model NonConformance {
  id           String    @id @default(cuid())
  ncNumber     String    @unique
  title        String
  description  String
  isoClause    String
  source       String
  severity     Severity
  status       String    @default("OPEN")
  dueDate      DateTime?
  comments     Comment[]
  auditLogs    AuditLog[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model OpportunityForImprovement {
  id          String   @id @default(cuid())
  ofiNumber   String   @unique
  title       String
  description String
  area        String
  benefit     String?
  status      String   @default("IDENTIFIED")
  priority    Priority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  entityType  String
  entityId    String
  createdAt   DateTime @default(now())

  incident    Incident?        @relation(fields: [incidentId], references: [id])
  incidentId  String?
  risk        Risk?            @relation(fields: [riskId], references: [id])
  riskId      String?
  action      CorrectiveAction? @relation(fields: [actionId], references: [id])
  actionId    String?
  change      ChangeRequest?   @relation(fields: [changeId], references: [id])
  changeId    String?
  nonConformance NonConformance? @relation(fields: [ncId], references: [id])
  ncId        String?
}

model Attachment {
  id         String   @id @default(cuid())
  filename   String
  url        String
  entityType String
  entityId   String
  uploadedAt DateTime @default(now())
  incident   Incident? @relation(fields: [incidentId], references: [id])
  incidentId String?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  entityType String
  entityId  String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  timestamp  DateTime @default(now())

  incident   Incident?         @relation(fields: [incidentId], references: [id])
  incidentId String?
  risk       Risk?             @relation(fields: [riskId], references: [id])
  riskId     String?
  action_    CorrectiveAction? @relation(fields: [actionId], references: [id])
  actionId   String?
  change     ChangeRequest?    @relation(fields: [changeId], references: [id])
  changeId   String?
  nc         NonConformance?   @relation(fields: [ncId], references: [id])
  ncId       String?
}

model ISOStandard {
  id       String @id @default(cuid())
  code     String @unique
  name     String
  clauses  ISOClause[]
}

model ISOClause {
  id         String      @id @default(cuid())
  standardId String
  standard   ISOStandard @relation(fields: [standardId], references: [id])
  clauseNum  String
  title      String
  description String?
}
